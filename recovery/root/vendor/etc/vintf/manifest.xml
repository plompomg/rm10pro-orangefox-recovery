<?xml version="1.0" encoding="UTF-8"?>
<!-- VINTF manifest for TWRP recovery -->
<!-- Device: Nubia RedMagic 10 Pro (NX789J) -->
<!-- Platform: Snapdragon 8 Elite (sun) / Android 15 -->
<manifest version="2.0" type="device" target-level="8">

    <!-- KeyMint - required for /data ICE wrappedkey decryption -->
    <hal format="aidl">
        <name>android.hardware.security.keymint</name>
        <fqname>IKeyMintDevice/default</fqname>
    </hal>

    <!-- Gatekeeper - required for credential-encrypted key derivation -->
    <hal format="aidl">
        <name>android.hardware.gatekeeper</name>
        <fqname>IGatekeeper/default</fqname>
    </hal>

    <!-- Secure Element - UICC-based, served by qcril telephony stack -->
    <hal format="aidl">
        <name>android.hardware.secure_element</name>
        <fqname>ISecureElement/SIM1</fqname>
        <fqname>ISecureElement/SIM2</fqname>
    </hal>

    <!-- NFC - ST21 NFC controller (ST NFC stack) -->
    <hal format="aidl">
        <name>android.hardware.nfc</name>
        <fqname>INfc/default</fqname>
    </hal>

</manifest>